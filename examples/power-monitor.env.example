# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID by messaging @userinfobot on Telegram
# or by sending a message to your bot and checking the Telegram API
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Custom log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
# Optional: Route Bot API calls through a reverse proxy (e.g. a Cloudflare Worker
# such as alt-glitch/hermes-telegram-proxy) when api.telegram.org is unreachable.
# Defaults to the official endpoints when unset. The trailing "/bot" and
# "/file/bot" are required - python-telegram-bot appends "<token>/<method>".
# TELEGRAM_BASE_URL=https://<your-worker>.workers.dev/bot
# TELEGRAM_BASE_FILE_URL=https://<your-worker>.workers.dev/file/bot
